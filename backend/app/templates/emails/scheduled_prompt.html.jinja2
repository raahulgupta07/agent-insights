<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
<head>
  <meta charset="utf-8">
  <title>{{ subject }}</title>
</head>
<body style="margin:0; padding:0; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; color:#222; font-size:14px; line-height:1.6;" dir="{{ dir }}">
  <div style="max-width:600px; padding:20px;" dir="{{ dir }}">
    <p>{{ t.greeting }}</p>
    <p>{{ intro_sentence }}</p>
    {% if summary_html %}
    {{ summary_html | safe }}
    {% endif %}
    <p><a href="{{ report_url }}">{{ t.cta_text }}</a></p>
    <p style="color:#999;">{{ t.footer }}</p>
  </div>
</body>
</html>
